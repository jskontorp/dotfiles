#!/usr/bin/env bash
# dev — Worktree + tmux launcher for parallel agent work in dotfiles.
#
# Usage: ./dev <slug>
#
# Creates <canonical-parent>/<canonical-basename>_worktrees/<slug> on a new
# branch from main, opens a tmux window <slug> in the `dotfiles` session,
# hands you a shell. Idempotent: re-running with the same slug selects the
# existing window. Canonical location resolved from this script's own path,
# so the script works regardless of where dotfiles is checked out.
#
# Constraints (deliberate, do not relax without re-reading AGENTS.md):
# - Run from canonical dotfiles only. Refuses elsewhere.
# - Slug must match [a-z0-9][a-z0-9-]* (lowercase, hyphens, no slashes/spaces).
# - Does NOT run install.sh, just link, pnpm install, or anything touching ~.
# - Does NOT lifecycle worktrees (no --remove, --shelve, --close, --list).
#   `git worktree remove` is the cleanup; this script does not garbage-collect.
# - Does NOT auto-launch pi/claude. Hands you a shell; you decide.
#
# This is the boring version on purpose. Two iterations of fancier helpers
# (zsh/graveyard/git-worktrees.zsh, machine/vm/bin/graveyard/sv) are in the
# graveyard; mine those for design notes before adding any feature here.

set -euo pipefail

# Hard-fail on missing tools we depend on later (per AGENTS.md regression
# class: "`set -e` + missing optional tool" — cfc4ba1, 070d150).
for tool in tmux git; do
  command -v "$tool" >/dev/null 2>&1 || { echo "❌ required tool not on PATH: $tool" >&2; exit 66; }
done

# Resolve canonical from this script's own location via pwd -P (matches
# install.sh:8 style; avoids realpath portability issues per AGENTS.md
# regression classes). Refuse if invoked from a worktree by comparing
# script dir against git-common-dir's parent.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
if git -C "$SCRIPT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  canonical_repo="$(dirname "$(git -C "$SCRIPT_DIR" rev-parse --path-format=absolute --git-common-dir)")"
  if [[ "$SCRIPT_DIR" != "$canonical_repo" ]]; then
    echo "❌ ./dev must be run from canonical dotfiles ($canonical_repo)" >&2
    echo "   got: $SCRIPT_DIR" >&2
    exit 65
  fi
else
  echo "❌ ./dev: $SCRIPT_DIR is not inside a git work tree" >&2
  exit 67
fi
CANONICAL="$SCRIPT_DIR"
SESSION="dotfiles"
# Worktrees sit next to canonical: <parent>/<basename>_worktrees/<slug>.
# Matches the convention used at ~/code/personal/dotfiles_worktrees on mac
# and /home/ubuntu/dotfiles_worktrees on the VM.
WT_BASE="$(dirname "$CANONICAL")/$(basename "$CANONICAL")_worktrees"

usage() {
  cat >&2 <<EOF
usage: ./dev <slug>
  slug: [a-z0-9][a-z0-9-]* (lowercase, hyphens; no slashes, no spaces)
EOF
  exit 64
}

[[ $# -eq 1 ]] || usage
SLUG="$1"

# Validate slug shape.
[[ "$SLUG" =~ ^[a-z0-9][a-z0-9-]*$ ]] || {
  echo "❌ slug must match [a-z0-9][a-z0-9-]* — got: '$SLUG'" >&2
  exit 64
}

WT="$WT_BASE/$SLUG"

# Worktree: create or reuse. Three cases:
#  - dir exists       → reuse (report current branch)
#  - dir missing, branch exists  → attach worktree to existing branch
#                                  (happens after `git worktree remove` left
#                                   the branch behind)
#  - dir missing, branch missing → fresh worktree + new branch from main
if [[ -d "$WT" ]]; then
  existing_branch="$(git -C "$WT" branch --show-current 2>/dev/null || echo '?')"
  echo "ℹ worktree exists: $WT (branch: $existing_branch)"
elif git -C "$CANONICAL" show-ref --verify --quiet "refs/heads/$SLUG"; then
  echo "→ attaching worktree: $WT to existing branch '$SLUG'"
  git -C "$CANONICAL" worktree add "$WT" "$SLUG"
else
  main_sha="$(git -C "$CANONICAL" rev-parse --short main)"
  echo "→ creating worktree: $WT (new branch '$SLUG' from main @ $main_sha)"
  echo "  (if main is stale: \`cd $CANONICAL && git fetch && git rebase origin/main\`, then re-run)"
  git -C "$CANONICAL" worktree add "$WT" -b "$SLUG" main
fi

# Tmux: probe-and-extend (never kill-session — see AGENTS.md regression class
# on shared tmux infra). Three cases: no session, session-with-window,
# session-without-window.
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "→ creating tmux session '$SESSION' with window '$SLUG'"
  tmux new-session -d -s "$SESSION" -n "$SLUG" -c "$WT"
elif tmux list-windows -t "$SESSION" -F '#W' 2>/dev/null | grep -qx "$SLUG"; then
  echo "ℹ tmux window exists: $SESSION:$SLUG (selecting)"
  tmux select-window -t "$SESSION:$SLUG"
else
  echo "→ creating tmux window: $SESSION:$SLUG"
  tmux new-window -t "$SESSION" -n "$SLUG" -c "$WT"
  tmux select-window -t "$SESSION:$SLUG"
fi

cat <<EOF
✅ ready: $WT
   peek: tmux attach -t $SESSION \\; select-window -t $SESSION:$SLUG
   cleanup (after merge): git worktree remove "$WT"
EOF
