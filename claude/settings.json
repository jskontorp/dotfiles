{
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(file:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git filter-branch:*)",
      "Bash(git reflog expire:*)",
      "Bash(git gc --prune=now:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile)",
      "Edit(~/.config/fish/**)",
      "Edit(~/.gitconfig)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/hooks/**)",
      "Edit(~/.claude/plugins/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(~/.zshrc)",
      "Write(~/.bashrc)",
      "Write(~/.zprofile)",
      "Write(~/.bash_profile)",
      "Write(~/.profile)",
      "Write(~/.config/fish/**)",
      "Write(~/.gitconfig)",
      "Write(~/.npmrc)",
      "Write(~/.pypirc)",
      "Write(~/.config/gh/**)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/hooks/**)",
      "Write(~/.claude/plugins/**)"
    ]
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "theme": "auto"
}
