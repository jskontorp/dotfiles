{
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(file:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(git -C * log *)",
      "Bash(git -C * status *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show *)",
      "Bash(git -C * blame *)",
      "Bash(git -C * shortlog *)",
      "Bash(git -C * describe *)",
      "Bash(git -C * ls-files *)",
      "Bash(git -C * ls-remote *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * cat-file *)",
      "Bash(git -C * for-each-ref *)",
      "Bash(git -C * stash list *)",
      "Bash(git -C * worktree list *)",
      "Bash(git -C * config --get *)",
      "Bash(curl -sL https://raw.githubusercontent.com/*)",
      "Bash(curl -sL https://api.github.com/*)",
      "Bash(uv run ruff check *)",
      "Bash(uv run mypy *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git filter-branch:*)",
      "Bash(git reflog expire:*)",
      "Bash(git gc --prune=now:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile)",
      "Edit(~/.config/fish/**)",
      "Edit(~/.gitconfig)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/hooks/**)",
      "Edit(~/.claude/plugins/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(~/.zshrc)",
      "Write(~/.bashrc)",
      "Write(~/.zprofile)",
      "Write(~/.bash_profile)",
      "Write(~/.profile)",
      "Write(~/.config/fish/**)",
      "Write(~/.gitconfig)",
      "Write(~/.npmrc)",
      "Write(~/.pypirc)",
      "Write(~/.config/gh/**)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/hooks/**)",
      "Write(~/.claude/plugins/**)"
    ]
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/session-scan/scan.sh"
          }
        ]
      }
    ]
  },
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
