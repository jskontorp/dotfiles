#!/bin/bash
# Pre-commit hook: shellcheck on staged .sh files + `just check` (justfile
# parity, manifest integrity, bash portability).
# Symlinked into .git/hooks/ by install.sh.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- shellcheck staged shell files ---
if command -v shellcheck &>/dev/null; then
  files=()
  while IFS= read -r f; do files+=("$f"); done < <(git diff --cached --name-only --diff-filter=ACM -- '*.sh')
  if [[ ${#files[@]} -gt 0 ]]; then
    printf "shellcheck: %d file(s)\n" "${#files[@]}"
    shellcheck -S warning "${files[@]}"
  fi
else
  printf "⚠ shellcheck not installed — skipping lint (brew install shellcheck)\n" >&2
fi

# --- just check (sub-second host-side suite) ---
if command -v just &>/dev/null; then
  ( cd "$REPO_ROOT" && just check >/dev/null ) || {
    printf "❌ just check failed — run \`just check\` to see details\n" >&2
    exit 1
  }
else
  printf "⚠ just not installed — skipping just check (run 'just init' or 'brew install just')\n" >&2
fi
