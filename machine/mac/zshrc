# --- Early local overrides (not tracked, runs before everything) ---
[[ -f ~/.zshrc.pre.local ]] && source ~/.zshrc.pre.local

# --- Homebrew ---
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"

# --- Completions ---
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
setopt always_to_end        # cursor moves to end after completion
setopt complete_in_word     # tab completes mid-word, not just at end
setopt auto_menu            # show completion menu on second tab

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt share_history
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_verify          # expand !! but show it before running
setopt extended_history     # timestamps in history

# --- Shell behaviour ---
setopt auto_cd              # type a dir name to cd into it
cdpath=(~/code ~/code/personal)
setopt interactivecomments  # allow # comments in terminal
export EDITOR="nvim"
export VISUAL="$EDITOR"

# --- Aliases ---
alias cat="bat --paging=never"
alias lg="lazygit"

# ls → eza
alias ls="eza --color=always --group-directories-first"
alias ll="eza -la --color=always --group-directories-first --icons"
alias la="eza -a --color=always --group-directories-first --icons"
alias lt="eza -T --color=always --group-directories-first --icons --level=2"

# --- PATH ---
export PATH="$HOME/.local/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- Plugins (Homebrew) ---
# Guard: these plugins wrap zle widgets and don't handle re-sourcing.
# Re-sourcing stacks wrappers (syntax-highlight → autosuggest → …) until
# FUNCNEST is hit.  Source once per session, skip on `source ~/.zshrc`.
BREW_PREFIX="$(brew --prefix)"
if [[ -z "${_DOTFILES_PLUGINS_SOURCED:-}" ]]; then
  source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
  _DOTFILES_PLUGINS_SOURCED=1
fi

# --- Tools ---
eval "$(fzf --zsh)"         # ctrl-r fuzzy history, ctrl-t file finder, alt-c cd
eval "$(zoxide init zsh)"   # z <partial> smart cd
eval "$(starship init zsh)"

# Emit OSC 7 so Ghostty (and other terminals) know the cwd for new tabs
autoload -Uz add-zsh-hook
__ghostty_osc7() {
  printf '\e]7;file://%s%s\a' "${HOST}" "${PWD}"
}
add-zsh-hook chpwd __ghostty_osc7
__ghostty_osc7  # emit once at shell startup

# --- Custom helpers (tracked in dotfiles/zsh/) ---
for f in ~/.config/zsh/*.zsh(N); do source "$f"; done

# --- Local overrides (not tracked) ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# --- Kiro CLI autosuggest conflict guard ---
# Kiro CLI bundles its own zsh-autosuggestions (prefixed _kiro_cli_autosuggest_*)
# that shares the "autosuggest-orig-" widget namespace with brew's version.
# If both end up loaded, the shared prefix creates circular widget references
# (infinite recursion → FUNCNEST).  Remove kiro's precmd rebinder if present,
# and tear down its widget wrappers so re-sourcing doesn't stack them.
if (( ${+functions[_kiro_cli_autosuggest_start]} )); then
  add-zsh-hook -d precmd _kiro_cli_autosuggest_start
  # Remove Kiro's bound widgets to break circular references
  local w
  for w in ${(k)widgets[(I)_kiro_cli_autosuggest_bound_*]}; do
    zle -D "$w" 2>/dev/null
  done
  for w in ${(k)functions[(I)_kiro_cli_autosuggest_*]}; do
    unfunction "$w" 2>/dev/null
  done
fi
