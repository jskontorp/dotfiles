# --- Early local overrides (not tracked, runs before everything) ---
[[ -f ~/.zshrc.pre.local ]] && source ~/.zshrc.pre.local

# --- Homebrew ---
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"

# --- Completions ---
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
setopt always_to_end        # cursor moves to end after completion
setopt complete_in_word     # tab completes mid-word, not just at end
setopt auto_menu            # show completion menu on second tab

# --- Shared config (history, aliases, PATH, terminal integration) ---
source ~/.config/zsh/core.zsh

# --- Mac-specific behaviour ---
cdpath=(~/code ~/code/personal ~/code/work)

# --- pnpm ---
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- Plugins (Homebrew) ---
# Guard: these plugins wrap zle widgets and don't handle re-sourcing.
# Re-sourcing stacks wrappers (syntax-highlight → autosuggest → …) until
# FUNCNEST is hit.  Source once per session, skip on `source ~/.zshrc`.
BREW_PREFIX="$(brew --prefix)"
if [[ -z "${_DOTFILES_PLUGINS_SOURCED:-}" ]]; then
  source_if "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  source_if "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
  _DOTFILES_PLUGINS_SOURCED=1
fi

# --- Tools ---
eval "$(fzf --zsh)"         # ctrl-r fuzzy history, ctrl-t file finder, alt-c cd
eval "$(zoxide init zsh)"   # z <partial> smart cd
eval "$(starship init zsh)"

# --- Custom helpers (tracked in dotfiles/zsh/) ---
for f in ~/.config/zsh/*.zsh(N); do
  [[ "${f:t}" == "core.zsh" ]] && continue
  source "$f"
done

# --- Local overrides (not tracked) ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# --- Kiro CLI autosuggest conflict guard ---
# Kiro CLI (as of March 2025) bundles its own zsh-autosuggestions prefixed
# _kiro_cli_autosuggest_* that shares the "autosuggest-orig-" widget namespace
# with Homebrew's version.  Both loaded → circular widget references → FUNCNEST.
# Tear down Kiro's copy so the Homebrew version wins cleanly.
#
# TODO: Remove once Kiro fixes the widget namespace collision, or if Kiro is
#       uninstalled.  Track: https://github.com/aws/kiro/issues (if public).
if (( ${+functions[_kiro_cli_autosuggest_start]} )); then
  add-zsh-hook -d precmd _kiro_cli_autosuggest_start
  local w
  for w in ${(k)widgets[(I)_kiro_cli_autosuggest_bound_*]}; do
    zle -D "$w" 2>/dev/null
  done
  for w in ${(k)functions[(I)_kiro_cli_autosuggest_*]}; do
    unfunction "$w" 2>/dev/null
  done
fi
