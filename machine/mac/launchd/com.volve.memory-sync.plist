<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Periodic bidirectional sync of the volve-ai project memory dir between
  mac and oracle. Mac-side initiator (no SSH server enabled on mac, no
  inbound port exposure). Reuses claude/hooks/volve-memory-sync.sh with
  VOLVE_MEMORY_SYNC_FORCE=1 so the script's CLAUDE_PROJECT_DIR filter
  doesn't noop the timer.

  $HOME literals are substituted to absolute paths by install.sh at
  materialisation time (launchd does NOT expand env vars inside
  ProgramArguments / StandardOutPath / StandardErrorPath).

  Activate:   launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.volve.memory-sync.plist
  Deactivate: launchctl bootout    gui/$(id -u)/com.volve.memory-sync
  Reload after editing this file: deactivate then activate (launchd caches
  the in-memory copy from bootstrap time and won't re-read on file change).
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.volve.memory-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>$HOME/.claude/hooks/volve-memory-sync.sh</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>VOLVE_MEMORY_SYNC_FORCE</key>
        <string>1</string>
        <key>HOME</key>
        <string>$HOME</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$HOME/Library/Logs/com.volve.memory-sync.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/com.volve.memory-sync.stderr.log</string>
</dict>
</plist>
