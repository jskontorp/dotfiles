# dotfiles — macOS recipes

DOTFILES := justfile_directory() / "../.."

# Show usage
@default:
    echo "dotfiles — macOS recipes"
    echo ""
    echo "Usage: just <recipe>"
    echo ""
    echo "Setup:"
    echo "  init          Full bootstrap (fresh machine)"
    echo "  update        Update Homebrew packages + tmux plugins"
    echo "  status        Show installed tool versions"
    echo ""
    echo "Management:"
    echo "  link          Re-symlink all configs"
    echo "  save [msg]    Commit and push dotfile changes"
    echo ""
    echo "Edit:"
    echo "  zsh           zshrc (reloads on save)"
    echo "  tmux          tmux.conf (reloads on save)"
    echo "  nvim          neovim config"
    echo "  ghostty      Ghostty terminal config"
    echo "  starship      prompt config"
    echo "  git           git config"

[private]
@assert-macos:
    [[ "$(uname)" == "Darwin" ]] || { echo "❌ Mac recipes are for macOS, not $(uname)"; exit 1; }

# Full bootstrap (fresh machine)
init: assert-macos
    {{DOTFILES}}/machine/mac/bootstrap.sh

# Update Homebrew packages + tmux plugins
update: assert-macos
    #!/usr/bin/env bash
    set -euo pipefail

    echo "📦 Homebrew packages..."
    brew update && brew upgrade && brew cleanup

    echo "📦 tmux plugins..."
    "$HOME/.tmux/plugins/tpm/bin/install_plugins"

    echo ""
    echo "✅ Update complete!"

# Show installed tool versions
status:
    #!/usr/bin/env bash
    printf "%-12s %s\n" "macOS"    "$(sw_vers -productVersion)"
    printf "%-12s %s\n" "chip"     "$(uname -m)"
    printf "%-12s %s\n" "zsh"      "$(zsh --version | awk '{print $2}')"
    printf "%-12s %s\n" "nvim"     "$(nvim --version | head -1 | awk '{print $2}')"
    printf "%-12s %s\n" "tmux"     "$(tmux -V | awk '{print $2}')"
    printf "%-12s %s\n" "node"     "$(node --version 2>/dev/null || echo 'missing')"
    printf "%-12s %s\n" "pnpm"     "$(pnpm --version 2>/dev/null || echo 'missing')"
    printf "%-12s %s\n" "git"      "$(git --version | awk '{print $3}')"
    printf "%-12s %s\n" "gh"       "$(gh --version | head -1 | awk '{print $3}')"
    printf "%-12s %s\n" "delta"    "$(delta --version 2>/dev/null | awk '{print $2}')"
    printf "%-12s %s\n" "starship" "$(starship --version | head -1 | awk '{print $2}')"
    printf "%-12s %s\n" "eza"      "$(eza --version | sed -n 2p | awk '{print $1}')"
    printf "%-12s %s\n" "bat"      "$(bat --version | awk '{print $2}')"
    printf "%-12s %s\n" "rg"       "$(rg --version | head -1 | awk '{print $2}')"
    printf "%-12s %s\n" "fzf"      "$(fzf --version | awk '{print $1}')"
    printf "%-12s %s\n" "fd"       "$(fd --version | awk '{print $2}')"
    printf "%-12s %s\n" "zoxide"   "$(zoxide --version 2>/dev/null | awk '{print $2}' || echo 'missing')"
    printf "%-12s %s\n" "lazygit"  "$(lazygit --version | head -1 | sed 's/.*version=//' | cut -d, -f1)"

# Symlink all configs into place
link:
    {{DOTFILES}}/install.sh

# Commit and push dotfile changes
save msg="update dotfiles":
    cd {{DOTFILES}} && git add -A
    cd {{DOTFILES}} && git commit -m "{{msg}}"
    cd {{DOTFILES}} && git push

# Edit configs (interactive — run from terminal)
[group('edit')]
zsh:
    nvim ~/.zshrc && source ~/.zshrc
[group('edit')]
tmux:
    nvim ~/.tmux.conf && tmux source-file ~/.tmux.conf
[group('edit')]
nvim:
    nvim ~/.config/nvim/
[group('edit')]
starship:
    nvim ~/.config/starship.toml
[group('edit')]
ghostty:
    nvim "$HOME/Library/Application Support/com.mitchellh.ghostty/config"
[group('edit')]
git:
    nvim ~/.gitconfig
