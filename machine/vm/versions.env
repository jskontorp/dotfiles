# Shared tool versions — sourced by justfile update recipe.
#
# Pinned: tools built from source where a bad release could break the build.
# Unpinned (fetched via GitHub "latest" API): bat, eza, delta, lazygit.
# These are stable binary downloads — a broken release changes the archive
# layout and the script fails visibly rather than installing bad software.
# "latest" is intentional to avoid manual version bumps for these.

TMUX_VERSION="3.5a"
