# --- Early local overrides (not tracked, runs before everything) ---
[[ -f ~/.zshrc.pre.local ]] && source ~/.zshrc.pre.local

# --- Completions ---
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# --- Key bindings ---
bindkey -e
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# --- Shared config (history, aliases, PATH, terminal integration) ---
source ~/.config/zsh/core.zsh

# --- fnm ---
if [[ -d "$HOME/.local/share/fnm" ]]; then
  case ":$PATH:" in
    *":$HOME/.local/share/fnm:"*) ;;
    *) export PATH="$HOME/.local/share/fnm:$PATH" ;;
  esac
  eval "$(fnm env)"
fi

# --- pnpm ---
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- Plugins (sourced directly, no framework) ---
# Guard: these plugins wrap zle widgets and don't handle re-sourcing.
# Re-sourcing stacks wrappers until FUNCNEST is hit.  Source once per session.
if [[ -z "${_DOTFILES_PLUGINS_SOURCED:-}" ]]; then
  source_if /usr/share/doc/fzf/examples/key-bindings.zsh
  source_if /usr/share/doc/fzf/examples/completion.zsh
  source_if "$HOME/.local/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
  source_if "$HOME/.local/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  _DOTFILES_PLUGINS_SOURCED=1
fi

# --- Tools ---
eval "$(zoxide init zsh)"
eval "$(starship init zsh)"

# --- Custom helpers (tracked in dotfiles/zsh/) ---
for f in ~/.config/zsh/*.zsh(N); do
  [[ "${f:t}" == "core.zsh" ]] && continue
  source "$f"
done

# --- Local overrides (not tracked) ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
